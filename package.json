{
  "name": "duel-deck-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#cards/*.js": "./src/cards/*.ts",
    "#duel/*.js": "./src/engine/duel/*.ts",
    "#engine/*.js": "./src/engine/*.ts",
    "#lua/*.js": "./src/engine/lua/*.ts",
    "#lua/duel-api/*.js": "./src/engine/lua/duel-api/*.ts",
    "#playtest/*.js": "./src/playtest/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "vite build && vite build --config vite.bridge.config.ts",
    "check:loc": "node tools/check-file-loc.mjs",
    "check:bridge-bundle": "node tools/check-bridge-bundle.mjs",
    "check": "bun run check:loc && bun run scan:lua-parity && bun run typecheck && bun run test && bun run build && bun run check:bridge-bundle",
    "dev": "vite --host 127.0.0.1",
    "setup:upstream": "node tools/setup-upstream.mjs",
    "probe:lua-deck": "node --experimental-transform-types tools/probe-lua-deck.ts",
    "scan:lua-api": "node tools/scan-lua-api-usage.mjs",
    "scan:lua-constants": "node tools/scan-lua-constants.mjs",
    "scan:lua-parity": "node tools/scan-lua-parity.mjs --fail-on-missing"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.25",
    "fengari": "^0.1.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
